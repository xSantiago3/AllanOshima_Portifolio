rules_version = '2';

// Default-deny: the `leads` and `ratelimits` collections are written ONLY by the
// Cloud Function via the Admin SDK (which bypasses these rules). No client SDK /
// REST access is ever allowed — submitter PII is never exposed publicly.
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
